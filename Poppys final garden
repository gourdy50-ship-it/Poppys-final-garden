-- Fullbright
MainTab:CreateToggle({
	Name = "Fullbright",
	CurrentValue = false,
	Flag = "FullbrightToggle",

	Callback = function(Value)

		local Lighting = game:GetService("Lighting")

		if Value then
			_G.OldBrightness = Lighting.Brightness
			_G.OldClockTime = Lighting.ClockTime
			_G.OldShadows = Lighting.GlobalShadows
			_G.OldAmbient = Lighting.OutdoorAmbient

			Lighting.Brightness = 2
			Lighting.ClockTime = 14
			Lighting.GlobalShadows = false
			Lighting.OutdoorAmbient = Color3.fromRGB(128,128,128)

		else
			Lighting.Brightness = _G.OldBrightness or 1
			Lighting.ClockTime = _G.OldClockTime or 12
			Lighting.GlobalShadows = _G.OldShadows or true
			Lighting.OutdoorAmbient = _G.OldAmbient or Color3.fromRGB(0,0,0)
		end

	end
})


-- Instant Skill Check
MainTab:CreateToggle({
	Name = "Instant Skill Check",
	CurrentValue = false,
	Flag = "InstantSkillCheck",

	Callback = function(Value)

		getgenv().scinstant = Value

		if Value then

			local event = game:GetService("ReplicatedStorage")
				.Events.SkillcheckUpdate

			local ogcb = getcallbackvalue(event,"OnClientInvoke")

			if ogcb then

				local old
				old = hookfunction(ogcb,function(...)

					if getgenv().scinstant then
						return "supercomplete"
					end

					return old(...)
				end)

				print("Skillcheck hooked")

			else
				warn("Skillcheck failed")
			end

		end

	end
})



local MonsterSet = {}

for _,v in pairs(MonsterNames) do
	MonsterSet[v] = true
end



local function AddESP(model)

	if model:FindFirstChild("MonsterESP") then
		return
	end


	local gui = Instance.new("BillboardGui")
	gui.Name = "MonsterESP"
	gui.Size = UDim2.new(0,150,0,40)
	gui.StudsOffset = Vector3.new(0,5,0)
	gui.AlwaysOnTop = true
	gui.Enabled = VisualsEnabled
	gui.Parent = model


	local text = Instance.new("TextLabel")
	text.Size = UDim2.new(1,0,1,0)
	text.BackgroundTransparency = 1
	text.Text = model.Name
	text.TextScaled = true
	text.TextColor3 = Color3.fromRGB(255,255,255)
	text.TextStrokeColor3 = Color3.fromRGB(255,0,0)
	text.TextStrokeTransparency = 0
	text.Parent = gui

end



local function Scan()

	for _,v in pairs(workspace:GetDescendants()) do

		if MonsterSet[v.Name]
		and v:IsA("Model") then

			AddESP(v)

		end
	end
end



VisualsTab:CreateToggle({
	Name = "Monster ESP",
	CurrentValue = false,
	Flag = "MonsterESP",

	Callback = function(Value)

		VisualsEnabled = Value

		Scan()

		for _,v in pairs(workspace:GetDescendants()) do

			if v:FindFirstChild("MonsterESP") then
				v.MonsterESP.Enabled = Value
			end

		end
	end
})



workspace.DescendantAdded:Connect(function(v)

	if VisualsEnabled
	and MonsterSet[v.Name]
	and v:IsA("Model") then

		task.wait(.2)
		AddESP(v)

	end

end)



